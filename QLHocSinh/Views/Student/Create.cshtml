@model Student

@{
    ViewData["Title"] = "Thêm Học sinh";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title mb-0">Thêm Học sinh mới</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @* Hiển thị tất cả lỗi từ ModelState bao gồm lỗi tạo User hoặc trùng mã HS *@
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6">
                        <h5 class="text-primary border-bottom pb-2">Thông tin học sinh</h5>

                        <div class="mb-3">
                            <label asp-for="StudentCode" class="form-label font-weight-bold">Mã Học Sinh</label>
                            <input asp-for="StudentCode" class="form-control" placeholder="Ví dụ: HS202401" />
                            <span asp-validation-for="StudentCode" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label font-weight-bold">Họ và Tên</label>
                            <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên đầy đủ" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DateOfBirth" class="form-label font-weight-bold">Ngày sinh</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ClassId" class="form-label font-weight-bold">Xếp Lớp</label>
                            <select asp-for="ClassId" class="form-select" asp-items="ViewBag.ClassId">
                                <option value="">-- Chọn Lớp học --</option>
                            </select>
                            <span asp-validation-for="ClassId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 border-start">
                        <h5 class="text-primary border-bottom pb-2">Tài khoản Phụ huynh</h5>

                        <p class="text-muted small">Chọn phụ huynh đã có trong hệ thống hoặc tạo tài khoản mới ngay lập tức.</p>

                        <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="pills-select-tab" data-bs-toggle="pill" data-bs-target="#pills-select" type="button" role="tab">Chọn có sẵn</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="pills-new-tab" data-bs-toggle="pill" data-bs-target="#pills-new" type="button" role="tab">Tạo mới</button>
                            </li>
                        </ul>

                        <div class="tab-content border p-3 rounded bg-light" id="pills-tabContent">
                            <div class="tab-pane fade show active" id="pills-select" role="tabpanel">
                                <div class="mb-3">
                                    <label asp-for="ParentId" class="form-label">Danh sách tài khoản phụ huynh</label>
                                    <select asp-for="ParentId" class="form-select" asp-items="ViewBag.ParentId">
                                        <option value="">-- Không bắt buộc (Có thể chọn sau) --</option>
                                    </select>
                                    <span asp-validation-for="ParentId" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="pills-new" role="tabpanel">
                                <div class="mb-3">
                                    <label class="form-label">Họ tên phụ huynh</label>
                                    <input name="NewParentFullName" class="form-control" placeholder="Nguyễn Văn A" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Email (Dùng làm tên đăng nhập)</label>
                                    <input name="NewParentEmail" type="email" class="form-control" placeholder="parent@example.com" />
                                </div>
                                <div class="alert alert-warning py-2 mb-0 shadow-sm">
                                    <i class="bi bi-info-circle"></i> Mật khẩu mặc định: <strong>Parent@@123</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 me-2">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="bi bi-save"></i> Lưu Học sinh
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Logic để xóa dữ liệu ở tab không sử dụng (tùy chọn để tránh gửi dữ liệu thừa)
        document.getElementById('pills-select-tab').addEventListener('shown.bs.tab', function () {
            document.getElementsByName('NewParentFullName')[0].value = '';
            document.getElementsByName('NewParentEmail')[0].value = '';
        });

        document.getElementById('pills-new-tab').addEventListener('shown.bs.tab', function () {
            document.getElementById('ParentId').value = '';
        });
    </script>
}