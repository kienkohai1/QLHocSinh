@model IEnumerable<Class>

@{
    ViewData["Title"] = "Quản lý Lớp học";
}

<h1>Danh sách Lớp học</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm Lớp Mới</a>
</p>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Tên lớp</th>
            <th>Năm học</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ClassName</td>
                <td>@item.SchoolYear</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Chi tiết</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>