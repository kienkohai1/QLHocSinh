@model IEnumerable<Student>

@{
    ViewData["Title"] = "Quản lý Học sinh";
}

<div class="card shadow border-0 mt-4 rounded-3">
    <!-- HEADER -->
    <div class="card-header bg-white py-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h4 class="mb-0 text-primary fw-bold">
                <i class="bi bi-people-fill me-2"></i>Danh sách Học sinh
            </h4>

            <a asp-action="Create" class="btn btn-primary px-3">
                <i class="bi bi-plus-circle me-1"></i> Thêm học sinh
            </a>
        </div>

        <!-- FILTER -->
        <form method="get" asp-action="Index" class="row g-2 mt-3">
            <div class="col-md-3">
                <select name="classId" class="form-select" asp-items="ViewBag.Classes">
                    <option value="">-- Tất cả lớp --</option>
                </select>
            </div>

            <div class="col-md-4">
                <input type="text" name="searchString" class="form-control"
                       placeholder="🔍 Tìm theo tên hoặc mã HS..."
                       value="@ViewBag.CurrentSearch" />
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">
                    <i class="bi bi-funnel"></i> Lọc
                </button>
            </div>

            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>

    <!-- BODY -->
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Mã HS</th>
                        <th>Họ và tên</th>
                        <th>Ngày sinh</th>
                        <th>Lớp học</th>
                        <th>Phụ huynh</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                <span class="fs-5">Chưa có dữ liệu học sinh</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-primary">
                                    @item.StudentCode
                                </td>

                                <td class="fw-bold">
                                    @item.FullName
                                </td>

                                <td>
                                    @item.DateOfBirth.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @if (item.Class != null)
                                    {
                                        <span class="badge bg-info bg-opacity-25 text-dark border border-info px-3 py-1 rounded-pill">
                                            @item.Class.ClassName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">
                                            Chưa xếp lớp
                                        </span>
                                    }
                                </td>

                                <td>
                                    @(item.Parent != null ? item.Parent.FullName :
                                        "<span class='text-muted fst-italic'>Chưa gắn</span>")
                                </td>

                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning" title="Sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa học sinh này không?');"
                                           title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>