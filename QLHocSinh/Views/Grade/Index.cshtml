@* Index.cshtml - Trang chọn lớp, môn, loại điểm để nhập *@
@{
    ViewData["Title"] = "Quản lý điểm - Nhập điểm học sinh";
}

<div class="container">
    <h2 class="mb-4">Nhập điểm học sinh</h2>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <form asp-action="Enter" method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Chọn lớp học</label>
                        <select name="classId" class="form-select" required>
                            <option value="" disabled selected>-- Chọn lớp --</option>
                            @foreach (var item in ViewBag.ListClasses)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Chọn môn học</label>
                        <select name="subjectId" class="form-select" required>
                            <option value="" disabled selected>-- Chọn môn --</option>
                            @foreach (var item in ViewBag.ListSubjects)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Loại điểm</label>
                        <select name="examType" class="form-select" required>
                            <option value="" disabled selected>-- Chọn loại điểm --</option>
                            @foreach (var item in ViewBag.ListExamTypes)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-arrow-right-circle"></i> Tiếp tục
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Optional: disable button khi submit để tránh double-click
        document.querySelector('form').addEventListener('submit', function () {
            const btn = this.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang xử lý...';
        });
    </script>
}