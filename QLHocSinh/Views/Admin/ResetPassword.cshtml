@model ApplicationUser

<h2>Cấp lại mật khẩu</h2>
<div class="alert alert-warning">
    Bạn đang đặt lại mật khẩu cho tài khoản: <strong>@Model.UserName</strong> (@Model.FullName)
</div>

<form asp-action="ResetPassword" method="post" class="w-50">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mb-3">
        <label>Nhập Mật khẩu mới</label>
        <input type="text" name="NewPassword" class="form-control" placeholder="Ví dụ: Abc@123456" required />
    </div>

    <button type="submit" class="btn btn-danger">Xác nhận đổi mật khẩu</button>
    <a asp-action="ManageUsers" class="btn btn-secondary">Quay lại</a>
</form>