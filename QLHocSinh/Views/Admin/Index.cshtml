@{
    ViewData["Title"] = "Bảng điều khiển Admin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-speedometer2"></i> Bảng điều khiển Quản trị viên
        </h2>
        <span class="text-muted">Xin chào, @User.Identity?.Name!</span>
    </div>
    <hr />

    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-3 border-bottom border-primary border-4">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-primary mb-3">🎓</div>
                    <h4 class="card-title fw-bold">Quản lý Học sinh</h4>
                    <p class="card-text text-muted">Thêm mới, cập nhật hồ sơ, xóa và xếp lớp cho học sinh toàn trường.</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-4">
                    <a asp-controller="Student" asp-action="Index" class="btn btn-primary w-75 rounded-pill">Truy cập ngay</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-3 border-bottom border-success border-4">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-success mb-3">👨‍🏫</div>
                    <h4 class="card-title fw-bold">Quản lý Giáo viên</h4>
                    <p class="card-text text-muted">Quản lý danh sách giáo viên, phân công chuyên môn và chủ nhiệm lớp.</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-4">
                    <a asp-controller="Teacher" asp-action="Index" class="btn btn-success w-75 rounded-pill">Truy cập ngay</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-3 border-bottom border-warning border-4">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-warning mb-3">👥</div>
                    <h4 class="card-title fw-bold">Quản lý Tài khoản</h4>
                    <p class="card-text text-muted">Cấp phát tài khoản đăng nhập cho Phụ huynh, Học sinh và Giáo viên mới.</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-4">
                    <a asp-controller="Admin" asp-action="ManageUsers" class="btn btn-warning text-dark fw-bold w-75 rounded-pill">Quản lý tài khoản</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-3 border-bottom border-info border-4">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-info mb-3">📚</div>
                    <h4 class="card-title fw-bold">Quản lý Môn học</h4>
                    <p class="card-text text-muted">Thêm mới, chỉnh sửa, xóa và thiết lập số tín chỉ/số tiết cho các môn học.</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-4">
                    <a asp-controller="Subject" asp-action="Index" class="btn btn-info text-white fw-bold w-75 rounded-pill">Truy cập ngay</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-3 border-bottom border-success border-4">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-success mb-3">📝</div>
                    <h4 class="card-title fw-bold">Quản lý Điểm số</h4>
                    <p class="card-text text-muted">Nhập điểm, cập nhật và theo dõi kết quả học tập của học sinh theo từng lớp và môn học.</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-4">
                    <a asp-controller="Grade" asp-action="Index" class="btn btn-success w-75 rounded-pill">Quản lý bảng điểm</a>
                </div>
            </div>
        </div>

    </div>
</div>