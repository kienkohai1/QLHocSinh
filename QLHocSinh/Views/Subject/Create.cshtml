@model Subject

@{
    ViewData["Title"] = "Thêm mới Môn học";
}

<div class="container mt-4">
    <h2>Thêm mới Môn học</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label">Tên môn học</label>
                    <input asp-for="Name" class="form-control" placeholder="VD: Toán, Ngữ Văn..." required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Credits" class="control-label">Số tín chỉ / Số tiết</label>
                    <input asp-for="Credits" class="form-control" type="number" min="1" required />
                    <span asp-validation-for="Credits" class="text-danger"></span>
                </div>

                <div class="form-group mt-4">
                    <input type="submit" value="Lưu Môn học" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}