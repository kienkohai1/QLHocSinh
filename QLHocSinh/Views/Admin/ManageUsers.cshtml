@model IEnumerable<ApplicationUser>
<h2>Quản lý Tài khoản</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<a asp-action="CreateUser" class="btn btn-primary mb-3">Tạo tài khoản mới</a>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Tên đăng nhập</th>
            <th>Họ và Tên</th>
            <th>Email</th>
            <th>Vai trò</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td><span class="badge bg-info text-dark">@user.UserRole</span></td>
                <td>
                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="ResetPassword" asp-route-id="@user.Id" class="btn btn-sm btn-secondary">Đổi MK</a>
                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?');">
                        <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>