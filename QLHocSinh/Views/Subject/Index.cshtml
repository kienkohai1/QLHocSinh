@model IEnumerable<Subject>

@{
    ViewData["Title"] = "Quản lý Môn học";
}

<div class="container mt-4">
    <h2>Danh sách Môn học</h2>

    <p>
        <a asp-action="Create" class="btn btn-primary">Thêm Môn học mới</a>
    </p>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Mã (ID)</th>
                <th>Tên Môn học</th>
                <th>Số Tín chỉ / Số tiết</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Credits</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a> |
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a> |
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">Chưa có môn học nào trong hệ thống.</td>
                </tr>
            }
        </tbody>
    </table>
</div>