@model Class

@{
    ViewData["Title"] = "Chi tiết Lớp học";
    // Kiểm tra an toàn xem danh sách học sinh có null không
    var studentCount = Model.Students != null ? Model.Students.Count : 0;
}

<h1>Chi tiết Lớp: <span class="text-primary">@Model.ClassName</span></h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Tên lớp</dt>
        <dd class="col-sm-10">@Model.ClassName</dd>

        <dt class="col-sm-2">Năm học</dt>
        <dd class="col-sm-10">@Model.SchoolYear</dd>

        <dt class="col-sm-2">Sĩ số</dt>
        <dd class="col-sm-10 font-weight-bold text-danger">@studentCount học sinh</dd>
    </dl>
</div>

<h3 class="mt-4">Danh sách học sinh</h3>

@if (studentCount > 0)
{
    <table class="table table-bordered table-hover mt-3">
        <thead class="table-light">
            <tr>
                <th>Mã HS (ID)</th>
                <th>Họ và Tên</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model.Students)
            {
                <tr>
                    <td>@student.Id</td>
                    <td>@student.FullName</td>
                    <td>
                        <a asp-controller="Student" asp-action="Details" asp-route-id="@student.Id" class="btn btn-sm btn-info text-white">Xem thông tin HS</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning mt-3">
        Lớp học này hiện tại chưa có học sinh nào.
    </div>
}

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa thông tin Lớp</a> |
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách lớp</a>
</div>